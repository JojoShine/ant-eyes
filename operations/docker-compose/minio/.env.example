# MinIO Docker Compose 环境变量配置
# 使用方法: 复制此文件为 .env 并修改相应的值

# MinIO Root 用户名 (至少3位)
MINIO_ROOT_USER=minioadmin

# MinIO Root 密码 (必填, 至少8位)
MINIO_ROOT_PASSWORD=YourStrongMinioPassword123!

# MinIO API 端口
MINIO_API_PORT=9000

# MinIO Console 端口
MINIO_CONSOLE_PORT=9001

# MinIO Console URL (可选)
MINIO_CONSOLE_URL=http://localhost:9001

# 时区
TZ=Asia/Shanghai
