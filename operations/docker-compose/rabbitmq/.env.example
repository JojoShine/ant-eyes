# RabbitMQ Docker Compose 环境变量配置
# 使用方法: 复制此文件为 .env 并修改相应的值

# RabbitMQ 管理员用户名
RABBITMQ_USER=admin

# RabbitMQ 管理员密码 (必填, 至少12位)
RABBITMQ_PASSWORD=YourStrongRabbitMQPassword123!

# RabbitMQ 虚拟主机
RABBITMQ_VHOST=/

# RabbitMQ AMQP 端口
RABBITMQ_AMQP_PORT=5672

# RabbitMQ Management 端口
RABBITMQ_MANAGEMENT_PORT=15672

# 时区
TZ=Asia/Shanghai
